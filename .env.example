# --- Required: agent runtime ---
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...            # service-role key (bypasses RLS) — NEVER expose client-side
RESEND_API_KEY=re_...

# --- Email identity / CAN-SPAM (set in GitHub repo Variables for CI) ---
# Use a verified custom sending domain for real outreach; the resend.dev test
# address is not deliverable to real subscribers.
MAIL_FROM=GrantEquity <grants@grantequity.org>
# Base URL of the deployed Supabase Edge Functions (no trailing /unsubscribe).
# Used to build the per-org unsubscribe link + List-Unsubscribe header.
UNSUBSCRIBE_BASE_URL=https://your-project.supabase.co/functions/v1
# Physical postal address shown in every email footer (CAN-SPAM). A PO box is fine.
MAILING_ADDRESS=GrantEquity, PO Box 000, Somewhere, NJ 07000

# --- Optional: manual single-org run ---
# When set, the agent sends a digest to ONLY this org (workflow_dispatch path).
# Leave unset for the weekly all-orgs run.
TARGET_ORG_EMAIL=

# --- Edge Function secrets (set via `supabase secrets set`, NOT in this file) ---
# CONFIRM_WEBHOOK_SECRET=...   # shared secret for the signup-confirmation DB webhook
# RESEND_WEBHOOK_SECRET=...    # Svix signing secret from the Resend webhook dashboard
