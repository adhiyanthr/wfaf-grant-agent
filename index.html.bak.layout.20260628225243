  <script>
    const SUPABASE_URL = 'https://ujixxuvfpuykcmzcebmg.supabase.co';
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVqaXh4dXZmcHV5a2NtemNlYm1nIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzOTQ4MDAsImV4cCI6MjA5Nzk3MDgwMH0.GckAxe3pHOoGhAE07mnrCyW_uoMR8FCmRT0mrkZnsNk';
    const supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    (function () {
      "use strict";

      var prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      /* ---------- EMAIL MOCKUP FADE-IN (only motion on the page) ---------- */
      var emailEl = document.getElementById("email-preview");
      if (emailEl) {
        if (prefersReduced || !("IntersectionObserver" in window)) {
          emailEl.classList.add("in-view");
        } else {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");
                io.unobserve(entry.target);
              }
            });
          }, { threshold: 0.2 });
          io.observe(emailEl);
        }
      }

      /* ---------- SUPABASE INSERT SUBMIT ---------- */
      var form = document.getElementById("intake-form");
      var success = document.getElementById("form-success");
      var errorMsg = document.getElementById("form-error");

      // Clear focus-area error when any checkbox is checked
      var focusCheckboxes = document.querySelectorAll("input[name='focus_areas[]']");
      var focusError = document.getElementById("focus-error");
      focusCheckboxes.forEach(function (cb) {
        cb.addEventListener("change", function () {
          if (focusError && document.querySelector("input[name='focus_areas[]']:checked")) {
            focusError.classList.remove("show");
          }
        });
      });

      if (form) {
        form.addEventListener("submit", async function (e) {
          e.preventDefault();
          errorMsg.classList.remove("show");

          // Collect focus_areas checkboxes
          const focusCheckboxesChecked = form.querySelectorAll('input[name="focus_areas[]"]:checked');
          const focusAreas = Array.from(focusCheckboxesChecked).map(cb => cb.value);

          if (focusAreas.length === 0) {
            // surface the dedicated inline error next to the checkbox group
            if (focusError) {
              focusError.classList.add("show");
              var grid = document.getElementById("focus-areas-grid");
              if (grid) grid.scrollIntoView({ behavior: prefersReduced ? "auto" : "smooth", block: "center" });
            }
            return;
          }

          // Map form fields to organizations table schema
          const payload = {
            name:              form.querySelector('[name="org_name"]').value.trim(),
            email:             form.querySelector('[name="email"]').value.trim(),
            focus_areas:       focusAreas,
            county:            form.querySelector('[name="county"]').value,
            is_501c3:          form.querySelector('[name="is_501c3"]').value === "yes",
            annual_budget:     form.querySelector('[name="annual_budget"]').value,
            grant_size_pref:   form.querySelector('[name="grant_size_pref"]').value,
            what_we_do:        form.querySelector('[name="what_we_do"]').value.trim(),
            target_population: form.querySelector('[name="target_population"]').value.trim() || null,
            active:            true
          };

          // Disable submit button during request
          const btn = form.querySelector('button[type="submit"]');
          const originalText = btn.innerHTML;
          btn.disabled = true;
          btn.innerHTML = 'Submitting…';

          try {
            const { error } = await supabaseClient
              .from('organizations')
              .insert([payload]);

            if (error) {
              // Duplicate email — org already subscribed
              if (error.code === '23505') {
                form.style.display = "none";
                success.querySelector('h3').textContent = "You're already in.";
                success.querySelector('p').innerHTML =
                  "We already have your org on file. Your grant emails come from grants@grantequity.org every Monday.";
                success.classList.add("show");
                success.scrollIntoView({ behavior: "smooth", block: "center" });
                return;
              }
              throw error;
            }

            // Success
            form.style.display = "none";
            success.classList.add("show");
            success.scrollIntoView({ behavior: "smooth", block: "center" });

          } catch (err) {
            console.error("Supabase insert error:", err);
            errorMsg.textContent =
              "Something went wrong. Please email grants@grantequity.org and we'll set you up.";
            errorMsg.classList.add("show");
            btn.disabled = false;
            btn.innerHTML = originalText;
          }
        });
      }
    })();
  </script>
